# Copy this file to .env and fill in your real values
# Then add these same values as Environment Variables in Vercel Dashboard

# Flask secret key (generate a strong random string)
SECRET_KEY=your-strong-secret-key-here

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/online_voting_system?retryWrites=true&w=majority

# Supabase project credentials
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
